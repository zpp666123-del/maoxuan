{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene-payload.schema.json",
  "title": "ScenePayload",
  "oneOf": [
    {"$ref": "#/$defs/noneScene"},
    {"$ref": "#/$defs/timelineScene"},
    {"$ref": "#/$defs/decisionScene"},
    {"$ref": "#/$defs/mapScene"},
    {"$ref": "#/$defs/relationsScene"}
  ],
  "$defs": {
    "base": {
      "type": "object",
      "required": ["type", "sceneQuestion", "sourceIds"],
      "properties": {
        "type": {"type": "string"},
        "sceneQuestion": {"type": "string", "maxLength": 240},
        "sourceIds": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^(src_|p_)[A-Za-z0-9_-]+$"}},
        "textAlternative": {"type": ["string", "null"], "maxLength": 1000}
      }
    },
    "noneScene": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {"const": "none"},
            "sceneQuestion": {"type": "string", "maxLength": 240},
            "sourceIds": {"type": "array", "maxItems": 0},
            "textAlternative": {"type": ["string", "null"], "maxLength": 1000}
          }
        }
      ]
    },
    "timelineScene": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["items"],
          "properties": {
            "type": {"const": "timeline"},
            "sceneQuestion": {"type": "string", "maxLength": 240},
            "sourceIds": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
            "textAlternative": {"type": ["string", "null"], "maxLength": 1000},
            "focusId": {"type": ["string", "null"]},
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 12,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "date", "label", "role", "sourceIds"],
                "properties": {
                  "id": {"type": "string"},
                  "date": {"type": "string", "maxLength": 32},
                  "label": {"type": "string", "maxLength": 100},
                  "description": {"type": ["string", "null"], "maxLength": 300},
                  "role": {"type": "string", "enum": ["long_term", "precursor", "trigger", "writing", "later"]},
                  "sourceIds": {"type": "array", "items": {"type": "string"}}
                }
              }
            }
          }
        }
      ]
    },
    "decisionScene": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["problem", "constraints", "options", "judgment", "action"],
          "properties": {
            "type": {"const": "decision"},
            "sceneQuestion": {"type": "string", "maxLength": 240},
            "sourceIds": {"type": "array", "items": {"type": "string"}},
            "textAlternative": {"type": ["string", "null"], "maxLength": 1000},
            "problem": {"$ref": "#/$defs/labeledNode"},
            "constraints": {"type": "array", "minItems": 1, "maxItems": 6, "items": {"$ref": "#/$defs/labeledNode"}},
            "options": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"$ref": "#/$defs/labeledNode"}},
            "judgment": {"$ref": "#/$defs/labeledNode"},
            "action": {"$ref": "#/$defs/labeledNode"}
          }
        }
      ]
    },
    "mapScene": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["places", "routes"],
          "properties": {
            "type": {"const": "map"},
            "sceneQuestion": {"type": "string", "maxLength": 240},
            "sourceIds": {"type": "array", "items": {"type": "string"}},
            "textAlternative": {"type": ["string", "null"], "maxLength": 1000},
            "places": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["placeId", "label", "longitude", "latitude", "precision"],
                "properties": {
                  "placeId": {"type": "string", "pattern": "^plc_[A-Za-z0-9_-]+$"},
                  "label": {"type": "string", "maxLength": 100},
                  "longitude": {"type": "number", "minimum": -180, "maximum": 180},
                  "latitude": {"type": "number", "minimum": -90, "maximum": 90},
                  "precision": {"type": "string", "enum": ["exact", "approximate", "region"]},
                  "role": {"type": ["string", "null"], "maxLength": 80}
                }
              }
            },
            "routes": {
              "type": "array",
              "maxItems": 8,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "fromPlaceId", "toPlaceId", "label"],
                "properties": {
                  "id": {"type": "string"},
                  "fromPlaceId": {"type": "string"},
                  "toPlaceId": {"type": "string"},
                  "label": {"type": "string", "maxLength": 100}
                }
              }
            }
          }
        }
      ]
    },
    "relationsScene": {
      "allOf": [
        {"$ref": "#/$defs/base"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["nodes", "edges"],
          "properties": {
            "type": {"const": "relations"},
            "sceneQuestion": {"type": "string", "maxLength": 240},
            "sourceIds": {"type": "array", "items": {"type": "string"}},
            "textAlternative": {"type": ["string", "null"], "maxLength": 1000},
            "nodes": {"type": "array", "minItems": 2, "maxItems": 10, "items": {"$ref": "#/$defs/labeledNode"}},
            "edges": {
              "type": "array",
              "minItems": 1,
              "maxItems": 20,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "from", "to", "relation", "sourceIds"],
                "properties": {
                  "id": {"type": "string"},
                  "from": {"type": "string"},
                  "to": {"type": "string"},
                  "relation": {"type": "string", "maxLength": 80},
                  "sourceIds": {"type": "array", "items": {"type": "string"}}
                }
              }
            }
          }
        }
      ]
    },
    "labeledNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "sourceIds"],
      "properties": {
        "id": {"type": "string"},
        "label": {"type": "string", "maxLength": 120},
        "description": {"type": ["string", "null"], "maxLength": 300},
        "sourceIds": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
