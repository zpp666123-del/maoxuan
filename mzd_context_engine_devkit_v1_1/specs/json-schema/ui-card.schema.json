{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ui-card.schema.json",
  "title": "UiCard",
  "type": "object",
  "additionalProperties": false,
  "required": ["slot", "status", "headline", "summary", "points", "sourceIds", "anchorIds", "generatedBy"],
  "properties": {
    "slot": {"type": "string", "enum": ["background", "situation", "thought"]},
    "status": {"type": "string", "enum": ["ready", "unavailable", "degraded"]},
    "headline": {"type": "string", "maxLength": 30},
    "summary": {"type": "string", "maxLength": 280},
    "points": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "sourceIds"],
        "properties": {
          "label": {"type": ["string", "null"], "maxLength": 30},
          "text": {"type": "string", "maxLength": 260},
          "sourceIds": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^(src_|p_)[A-Za-z0-9_-]+$"}
          }
        }
      }
    },
    "sourceIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^(src_|p_)[A-Za-z0-9_-]+$"}
    },
    "anchorIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^anc_[A-Za-z0-9_-]+$"}
    },
    "uncertainty": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "level": {"type": "string", "enum": ["none", "low", "medium", "high"]},
        "note": {"type": ["string", "null"], "maxLength": 300}
      }
    },
    "generatedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "promptVersion"],
      "properties": {
        "kind": {"type": "string", "enum": ["editorial", "dynamic_ai"]},
        "promptVersion": {"type": ["string", "null"], "maxLength": 100},
        "runId": {"type": ["string", "null"], "pattern": "^run_[A-Za-z0-9_-]+$"}
      }
    }
  }
}
